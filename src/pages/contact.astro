---
import Container from "@/components/container.astro";
import Sectionhead from "@/components/sectionhead.astro";
import Layout from "@/layouts/Layout.astro";
import { Icon } from "astro-icon/components";
---

<Layout title="Contact">
  <Container>
    <Sectionhead>
      <Fragment slot="title">お問い合わせ</Fragment>
      <Fragment slot="desc">ご相談やご質問はこちら</Fragment>
    </Sectionhead>

    <div class="grid md:grid-cols-2 gap-10 mx-auto max-w-4xl mt-16">
      <div>
        <h2 class="font-medium text-2xl text-gray-800">お問い合わせ</h2>
        <p class="text-lg leading-relaxed text-slate-500 mt-3">
          testingosaka(at)googlegroups.com、あるいはDiscordにてご相談ください。
        </p>
        <div class="mt-5">
          <div class="flex items-center mt-2 space-x-2 text-gray-600">
            <Icon class="text-gray-400 w-4 h-4" name="uil:envelope" />
            <span>testingosaka(at)googlegroups.com</span>
          </div>
          <div class="flex items-center mt-2 space-x-2 text-gray-600">
            <Icon class="text-gray-400 w-4 h-4" name="simple-icons:discord" />
            <span>Discordコミュニティ</span>
          </div>
        </div>
      </div>
    </div>
  </Container>
</Layout>
